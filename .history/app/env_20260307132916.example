# ============================================================
# 心理测评辩论平台 —— 环境变量配置
# 复制此文件为 .env 并填入实际的 API 密钥
# ============================================================

SECRET_KEY=your-secret-key-here

# ============================================================
# 数据库配置（三选一，取消注释对应行）
# ============================================================

# 选项 1：SQLite（本地开发用，无需额外服务）
# DATABASE_URL=sqlite:///debate.db

# 选项 2：内置 MySQL 容器（docker-compose up -d 默认使用，无需修改）
# DATABASE_URL=mysql+pymysql://debate_user:debate_pass@db:3306/debate_db

# 选项 3：外部 MySQL 服务器（填入你自己的连接信息）
# DATABASE_URL=mysql+pymysql://用户名:密码@主机地址:3306/数据库名
DATABASE_URL=mysql+pymysql://debate_user:debate_pass@db:3306/debate_db

# ── 内置 MySQL 容器账号（仅 docker-compose 内置 db 服务时生效）──
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=debate_db
MYSQL_USER=debate_user
MYSQL_PASSWORD=debate_pass

# ============================================================
# "加持"模型配置 —— 用于润色学生观点
# ============================================================
ENHANCE_MODEL_API_URL=https://api.example.com/v1/chat/completions
ENHANCE_MODEL_API_KEY=your-enhance-api-key
ENHANCE_MODEL_NAME=gpt-4o-mini

# ============================================================
# "反驳"模型配置 —— 共用同一个 API，模型名称列表在 config.py 中配置
# ============================================================
REFUTE_MODEL_API_URL=https://api.example.com/v1/chat/completions
REFUTE_MODEL_API_KEY=your-refute-api-key
