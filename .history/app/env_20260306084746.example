# ============================================================
# 心理测评辩论平台 —— 环境变量配置
# 复制此文件为 .env 并填入实际的 API 密钥
# ============================================================

SECRET_KEY=your-secret-key-here

# 数据库配置（默认使用 SQLite）
DATABASE_URL=sqlite:///debate.db

# ============================================================
# "加持"模型配置 —— 用于润色学生观点
# ============================================================
ENHANCE_MODEL_API_URL=https://api.example.com/v1/chat/completions
ENHANCE_MODEL_API_KEY=your-enhance-api-key
ENHANCE_MODEL_NAME=gpt-4o-mini

# ============================================================
# "反驳"模型配置 —— 支持多个模型，随机抽取
# ============================================================

# 反驳模型 A
REFUTE_MODEL_A_API_URL=https://api.example.com/v1/chat/completions
REFUTE_MODEL_A_API_KEY=your-refute-a-api-key
REFUTE_MODEL_A_NAME=gpt-4o

# 反驳模型 B
REFUTE_MODEL_B_API_URL=https://api.example.com/v1/chat/completions
REFUTE_MODEL_B_API_KEY=your-refute-b-api-key
REFUTE_MODEL_B_NAME=claude-3-sonnet

# 反驳模型 C
REFUTE_MODEL_C_API_URL=https://api.example.com/v1/chat/completions
REFUTE_MODEL_C_API_KEY=your-refute-c-api-key
REFUTE_MODEL_C_NAME=deepseek-chat
